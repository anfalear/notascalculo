\@writefile{lof}{\contentsline {figure}{\numberline {22.1}{\ignorespaces Acción de la matriz $A=\left (\begin {smallmatrix}2&1\\1&2\end  {smallmatrix}\right )$ sobre dos vectores. El vector propio $\mathbf  {v}=(1,1)$ no cambia de dirección: solo se estira, $A\mathbf  {v}=3\mathbf  {v}$, y su recta $E_{3}$ queda invariante. En cambio, el vector genérico $\mathbf  {w}=(1,0)$ sí gira: $A\mathbf  {w}=(2,1)$ no es múltiplo de $\mathbf  {w}$.}}{476}{figure.22.1}\protected@file@percent }
\newlabel{fig:accion_vector_propio}{{22.1}{476}{Acción de la matriz $A=\left (\begin {smallmatrix}2&1\\1&2\end {smallmatrix}\right )$ sobre dos vectores. El vector propio $\mathbf {v}=(1,1)$ no cambia de dirección: solo se estira, $A\mathbf {v}=3\mathbf {v}$, y su recta $E_{3}$ queda invariante. En cambio, el vector genérico $\mathbf {w}=(1,0)$ sí gira: $A\mathbf {w}=(2,1)$ no es múltiplo de $\mathbf {w}$}{figure.22.1}{}}
