\contentsline {figure}{\numberline {14.8}{\ignorespaces Curvas que cumplen la condición del problema \ref {problemapolinomios}}}{337}{figure.14.8}%
\contentsline {figure}{\numberline {14.9}{\ignorespaces Flujos en una refinería de petróleo}}{339}{figure.14.9}%
\contentsline {figure}{\numberline {14.10}{\ignorespaces Tráfico proyectado en el parque principal}}{343}{figure.14.10}%
