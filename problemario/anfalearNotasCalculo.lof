\contentsline {figure}{\numberline {1.1}{\ignorespaces Recta numérica o eje real. La distancia de cada punto al origen es su valor absoluto.}}{17}{figure.1.1}%
\contentsline {figure}{\numberline {1.2}{\ignorespaces Soluciones de $|2x-3|=5$: los puntos $x=-1$ y $x=4$ equidistan $5/2$ del centro $x=3/2$.}}{18}{figure.1.2}%
\contentsline {figure}{\numberline {1.3}{\ignorespaces Conjunto solución de $|3x+1|\leq 4$: vecindad cerrada de centro $-1/3$ y radio $4/3$, extremos incluidos.}}{19}{figure.1.3}%
\contentsline {figure}{\numberline {1.4}{\ignorespaces Soluciones de $|x-2|+|x+1|=5$: cada solución suma distancia $5$ a los centros $-1$ y $2$ ($1+4$ desde $x=-2$; $4+1$ desde $x=3$).}}{19}{figure.1.4}%
\contentsline {figure}{\numberline {1.5}{\ignorespaces Representación en el círculo unitario: $x = \cos \theta $, $y = \mathop {\mathgroup \symoperators sen}\nolimits \theta $, con $x^2 + y^2 = 1$.}}{20}{figure.1.5}%
\contentsline {figure}{\numberline {1.6}{\ignorespaces El intervalo abierto $(-1,1)$ en la recta real: los extremos excluidos se marcan con círculos vacíos.}}{20}{figure.1.6}%
\contentsline {figure}{\numberline {1.7}{\ignorespaces Vecindad abierta $V_\varepsilon (x_0) = (x_0-\varepsilon ,\, x_0+\varepsilon )$: intervalo centrado en $x_0$ de radio $\varepsilon $.}}{21}{figure.1.7}%
\contentsline {figure}{\numberline {1.8}{\ignorespaces El supremo y el ínfimo de un conjunto acotado $S$. Con $\alpha = \sup S$: toda cota superior ($M_1$, $M_2$) queda a la derecha de $\alpha $, y para todo $\varepsilon > 0$ la franja $(\alpha -\varepsilon ,\,\alpha ]$ contiene algún $x \in S$.}}{21}{figure.1.8}%
\contentsline {figure}{\numberline {1.9}{\ignorespaces Los puntos $\tfrac {n}{n+1}$ crecen hacia el supremo $1$ sin alcanzarlo; el mínimo $\tfrac {1}{2}$, que es el ínfimo, sí pertenece a $S$.}}{22}{figure.1.9}%
\contentsline {figure}{\numberline {1.10}{\ignorespaces El conjunto $S = \{(-1)^n/n\}$ alterna de signo y se acumula en $0$; sus extremos $-1$ y $\tfrac {1}{2}$ se alcanzan en los dos primeros términos.}}{22}{figure.1.10}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {2.1}{\ignorespaces Representación geométrica del complejo $-5-4i.$}}{30}{figure.2.1}%
\contentsline {figure}{\numberline {2.2}{\ignorespaces Módulo y argumento de $z=a+bi$: el módulo $\left \vert z\right \vert =\sqrt {a^2+b^2}$ es la distancia del origen al punto $(a,b)$ y el argumento $\theta $ es el ángulo medido desde el eje real positivo.}}{30}{figure.2.2}%
\contentsline {figure}{\numberline {2.3}{\ignorespaces Representación gráfica de la solución}}{31}{figure.2.3}%
\contentsline {figure}{\numberline {2.4}{\ignorespaces Representación de la región del Ejemplo \ref {comprepex}}}{32}{figure.2.4}%
\contentsline {figure}{\numberline {2.5}{\ignorespaces Las seis raíces sextas de la unidad ($z^6=1$): todas tienen módulo $1$ y sus argumentos $\frac {2k\pi }{6}$, con $k=0,\dots ,5$, difieren consecutivamente en $\frac {2\pi }{6}$, por lo que forman un hexágono regular inscrito en la circunferencia unitaria.}}{33}{figure.2.5}%
\contentsline {figure}{\numberline {2.6}{\ignorespaces Representación gráfica en \texttt {matplotlib} del complejo $-5-4i.$}}{38}{figure.2.6}%
\contentsline {figure}{\numberline {2.7}{\ignorespaces Figura del problema \ref {compsombreado}}}{40}{figure.2.7}%
\contentsline {figure}{\numberline {2.8}{\ignorespaces Figura del problema \ref {compubicacion}}}{41}{figure.2.8}%
\contentsline {figure}{\numberline {2.9}{\ignorespaces Solución del problema \ref {compubicacion}}}{41}{figure.2.9}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {3.1}{\ignorespaces Dominio y rango como proyecciones de la gráfica: $D_f$ es la sombra de la curva sobre el eje $x$; $R_f$, su sombra sobre el eje $y$.}}{54}{figure.3.1}%
\contentsline {figure}{\numberline {3.2}{\ignorespaces Gráfica de $C(x)$ del Ejemplo \ref {ex:costo-contenedor}: el mínimo ocurre aproximadamente en $x \approx 1.65\,\mathrm {m}$.}}{56}{figure.3.2}%
\contentsline {figure}{\numberline {3.3}{\ignorespaces La circunferencia unitaria falla la prueba de la recta vertical.}}{57}{figure.3.3}%
\contentsline {figure}{\numberline {3.4}{\ignorespaces Función por tramos con salto en $x=2$: círculo abierto en $(2,2)$ (valor no alcanzado) y punto sólido en $(2,-1)$ (valor de la función).}}{58}{figure.3.4}%
\contentsline {figure}{\numberline {3.5}{\ignorespaces \emph {Izquierda:} potencias pares (simétricas respecto al eje $y$; $x^4$ más \emph {achatada} cerca del origen que $x^2$). \emph {Derecha:} potencias impares (simétricas respecto al origen).}}{59}{figure.3.5}%
\contentsline {figure}{\numberline {3.6}{\ignorespaces $f(x)=1/x$ con asíntota en $x=0$ ($D_f=\mathbb {R}\setminus \{0\}$); $g(x)=x^{2/3}$ con cúspide en el origen ($D_g=\mathbb {R}$).}}{59}{figure.3.6}%
\contentsline {figure}{\numberline {3.7}{\ignorespaces $f(x)=2^x$ creciente; $g(x)=(1/2)^x$ decreciente. Ambas pasan por $(0,1)$ y tienen asíntota $y=0$.}}{60}{figure.3.7}%
\contentsline {figure}{\numberline {3.8}{\ignorespaces $\log _2 x$ y $\ln x$ comparten el punto $(1,0)$; $\log _2 x > \ln x$ para $x > 1$ pues $\log _2 x = \ln x / \ln 2 \approx 1.44\ln x$.}}{60}{figure.3.8}%
\contentsline {figure}{\numberline {3.9}{\ignorespaces $\mathop {\mathgroup \symoperators sen}\nolimits x$ (azul) y $\cos x$ (naranja): período $2\pi $, amplitud 1. Observe que $\cos x = \mathop {\mathgroup \symoperators sen}\nolimits (x+\pi /2)$.}}{61}{figure.3.9}%
\contentsline {figure}{\numberline {3.10}{\ignorespaces $\tan x$: período $\pi $, asíntotas verticales en $x = \pi /2 + k\pi $.}}{61}{figure.3.10}%
\contentsline {figure}{\numberline {3.11}{\ignorespaces Traslaciones de $y=x^2$: el vértice se desplaza de $(0,0)$ a $(h,k)$.}}{62}{figure.3.11}%
\contentsline {figure}{\numberline {3.12}{\ignorespaces Parámetros de la forma amplitud-fase en $y=C+A\mathop {\mathgroup \symoperators sen}\nolimits [a(t-b)]$.}}{63}{figure.3.12}%
\contentsline {figure}{\numberline {3.13}{\ignorespaces La gráfica de $f^{-1}$ es la reflexión de la de $f$ respecto a la recta $y=x$: cada punto $(a,b)$ de $f$ corresponde al punto $(b,a)$ de $f^{-1}$, como ilustran $e^x$ y $\ln x$.}}{65}{figure.3.13}%
\contentsline {figure}{\numberline {3.14}{\ignorespaces Las tres inversas trigonométricas principales. Las líneas punteadas indican las asíntotas del rango.}}{67}{figure.3.14}%
\contentsline {figure}{\numberline {3.15}{\ignorespaces Ventana normanda: rectángulo de ancho $x$ coronado por un semicírculo.}}{70}{figure.3.15}%
\contentsline {figure}{\numberline {3.16}{\ignorespaces Caja sin tapa: Hoja de cartón de $20 \times 12$ cm con cuadrados de lado $x$ recortados en las esquinas}}{71}{figure.3.16}%
\contentsline {figure}{\numberline {3.17}{\ignorespaces Patrón para la tienda de acampar (pirámide de base cuadrada): cuadrado de $5\,\mathrm {m}$ de lado; $x$ es la distancia del centro al lado de la base.}}{71}{figure.3.17}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {4.1}{\ignorespaces Representación gráfica de la discontinuidad evitable en $x=1$.}}{74}{figure.4.1}%
\contentsline {figure}{\numberline {4.2}{\ignorespaces Definición $\epsilon $-$\delta $: fijada la tolerancia $\epsilon $ alrededor de $L$ (banda horizontal), existe $\delta $ tal que todo $x$ del entorno perforado $(c-\delta ,\,c+\delta )$ tiene imagen dentro de la banda. El valor $f(c)$, si existe, es irrelevante (punto excluido).}}{74}{figure.4.2}%
\contentsline {figure}{\numberline {4.3}{\ignorespaces Interpretación geométrica de la demostración: la banda $5\pm \epsilon $ y el entorno $3\pm \delta $ con $\delta =\epsilon /2$.}}{75}{figure.4.3}%
\contentsline {figure}{\numberline {4.4}{\ignorespaces Comparación de áreas: triángulo inscrito $\subset $ sector $\subset $ triángulo circunscrito.}}{78}{figure.4.4}%
\contentsline {figure}{\numberline {4.5}{\ignorespaces $f(x)=1/(x-2)$: asíntota vertical $x=2$ (los valores crecen sin cota al acercarse a $2$) y asíntota horizontal $y=0$ (la función se aplana hacia el eje $x$ cuando $x\to \pm \infty $).}}{79}{figure.4.5}%
\contentsline {figure}{\numberline {4.6}{\ignorespaces Tres tipos de discontinuidad en $x=c$: removible (el límite existe pero difiere de $f(c)$), de salto (límites laterales distintos) e infinita (asíntota vertical).}}{81}{figure.4.6}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {5.1}{\ignorespaces La recta secante por $P=(x_0,f(x_0))$ y un punto $Q=(x_0+h,f(x_0+h))$ tiende a la recta \emph {tangente} en $P$ cuando $Q\to P$ (es decir, $h\to 0$); su pendiente $\dfrac {f(x_0+h)-f(x_0)}{h}$ tiende a $f'(x_0)$.}}{90}{figure.5.1}%
\contentsline {figure}{\numberline {5.2}{\ignorespaces Árbol de dependencias de la regla de la cadena para $y=f(u)$, $u=g(x)$: la tasa de cambio total $dy/dx$ es el producto de las tasas a lo largo de la cadena $y\to u\to x$.}}{94}{figure.5.2}%
\contentsline {figure}{\numberline {5.3}{\ignorespaces Un círculo de radio $r$ inscrito en la parábola $y = x^2$.}}{107}{figure.5.3}%
\contentsline {figure}{\numberline {5.4}{\ignorespaces Triángulo equilátero formado por el eje $x$ y las rectas tangentes.}}{107}{figure.5.4}%
\contentsline {figure}{\numberline {5.5}{\ignorespaces Lámpara en $(3,h)$, elipse $x^2+4y^2=5$ y borde de sombra en $(-5,0)$.}}{108}{figure.5.5}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {6.1}{\ignorespaces Corte transversal del tanque cónico invertido: por semejanza de triángulos, el radio de la superficie libre es proporcional a la profundidad $h$ del agua.}}{110}{figure.6.1}%
\contentsline {figure}{\numberline {6.2}{\ignorespaces Escalera de $10$ m apoyada en la pared: al alejarse la base a razón $dx/dt$, el extremo superior desciende, ligados por $x^2+y^2=100$.}}{111}{figure.6.2}%
\contentsline {figure}{\numberline {6.3}{\ignorespaces Monotonía de $f(x)=x^3-3x$: la curva se colorea según el signo de $f'$.}}{114}{figure.6.3}%
\contentsline {figure}{\numberline {6.4}{\ignorespaces Concavidad de $f(x)=x^4-4x^3$: en azul los tramos donde $f''>0$ (curva abre hacia arriba) y en rojo donde $f''<0$ (curva abre hacia abajo). Los puntos negros señalan los puntos de inflexión.}}{116}{figure.6.4}%
\contentsline {figure}{\numberline {6.5}{\ignorespaces Bosquejo de $f(x)=\dfrac {x^2}{x^2-4}$. Las ramas azules son cóncavas hacia arriba y las rojas hacia abajo. Las líneas grises punteadas indican las asíntotas $x=\pm 2$ e $y=1$.}}{120}{figure.6.5}%
\contentsline {figure}{\numberline {6.6}{\ignorespaces Construcción de la caja abierta: se recortan cuadrados de lado $x$ en las esquinas de la lámina de $24\times 9$ cm y se doblan los bordes, quedando una base de $(24-2x)\times (9-2x)$ y altura $x$.}}{121}{figure.6.6}%
\contentsline {figure}{\numberline {6.7}{\ignorespaces Lata cilíndrica abierta de radio $r$ y altura $h$: el material total es el área de la base $\pi r^2$ más la pared lateral $2\pi r h$.}}{122}{figure.6.7}%
\contentsline {figure}{\numberline {6.8}{\ignorespaces Tendido de tubería: cruce del río (ancho $3$ km) desde $A$ hasta el punto $C$ a distancia $x$ de $P$, y tramo terrestre $C\to B$ de longitud $8-x$. El tramo submarino mide $\sqrt {9+x^2}$.}}{123}{figure.6.8}%
\contentsline {figure}{\numberline {6.9}{\ignorespaces Teorema del Valor Medio: existe $c\in (a,b)$ donde la recta tangente (verde) es paralela a la secante (roja) que une $A=(a,f(a))$ con $B=(b,f(b))$; en ese punto $f'(c)=\dfrac {f(b)-f(a)}{b-a}$.}}{124}{figure.6.9}%
\contentsline {figure}{\numberline {6.10}{\ignorespaces Cuadrado inscrito en una circunferencia de radio $r$: la diagonal del cuadrado es el diámetro $2r$, de modo que su lado es $r\sqrt 2$.}}{132}{figure.6.10}%
\contentsline {figure}{\numberline {6.11}{\ignorespaces Niño en bicicleta sobre el eje $x$ y globo que asciende manteniendo una separación lateral fija de $45$ ft; $L(t)$ es la distancia entre ambos a los $3$ s.}}{133}{figure.6.11}%
\contentsline {figure}{\numberline {6.12}{\ignorespaces Disposición geométrica del mecanismo y definición de variables.}}{133}{figure.6.12}%
\contentsline {figure}{\numberline {6.13}{\ignorespaces Gráfica de la derivada $f'$: los ceros de $f'$ señalan los posibles extremos de $f$, el signo de $f'$ su monotonía, y el crecimiento o decrecimiento de $f'$ la concavidad de $f$.}}{135}{figure.6.13}%
\contentsline {figure}{\numberline {6.14}{\ignorespaces Trayecto mixto: se trota de $A$ a $C$ (distancia $x$ a lo largo de la costa, $12$ km de $A$ a $D$) y se nada de $C$ al helicóptero $B$, situado $5$ km mar adentro. Se minimiza el tiempo total.}}{136}{figure.6.14}%
\contentsline {figure}{\numberline {6.15}{\ignorespaces Ángulo de visión $\theta $ de la pantalla $AB$ (segmento vertical entre $A(0,1)$ y $B(0,3)$) desde un asiento $C=(x,x)$ sobre la recta $y=x$.}}{136}{figure.6.15}%
\contentsline {figure}{\numberline {6.16}{\ignorespaces Dos astas verticales (alturas $2$ m y $1$ m, bases separadas $3$ m) unidas por un cable anclado en el suelo a distancia $x$ de la base más alta; se minimiza la longitud total $d_1+d_2$.}}{137}{figure.6.16}%
