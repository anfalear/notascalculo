\contentsline {figure}{\numberline {24.1}{\ignorespaces InterpretaciĂłn geomĂŠtrica de las derivadas parciales: la curva roja (corte $y=y_0$) tiene recta tangente (roja punteada) con pendiente $f_x(x_0,y_0)$; la curva azul (corte $x=x_0$) tiene recta tangente (azul punteada) con pendiente $f_y(x_0,y_0)$.}}{532}{figure.24.1}%
\contentsline {figure}{\numberline {24.2}{\ignorespaces Plano tangente (naranja) a $z=x^2+y^2$ en $(1,0,1)$ con vector normal $\mathbf {n}$ perpendicular al plano}}{538}{figure.24.2}%
\contentsline {figure}{\numberline {24.3}{\ignorespaces AproximaciĂłn lineal: $dz$ (plano tangente) aproxima $\Delta z$ (cambio real en la superficie) para incrementos pequeĂąos $\Delta x$}}{542}{figure.24.3}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {25.1}{\ignorespaces Curvas de nivel de $f(x,y)=x^2+\tfrac {y^2}{4}$ (elipses) con vectores $\nabla f$ en cuatro puntos, perpendiculares a las curvas de nivel}}{552}{figure.25.1}%
\contentsline {figure}{\numberline {25.2}{\ignorespaces Derivada direccional $D_{\mathbf {u}}f(P)$ como pendiente de la curva de intersecciĂłn de la superficie $z=f(x,y)$ con el plano vertical en direcciĂłn $\mathbf {u}$}}{553}{figure.25.2}%
\contentsline {figure}{\numberline {25.3}{\ignorespaces TriĂĄngulo con lados $x$, $y$ y ĂĄngulo $\theta $ para el problema de razĂłn de cambio.}}{559}{figure.25.3}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {26.1}{\ignorespaces Punto de silla en el origen de $z=x^2-y^2$: curvatura positiva en direcciĂłn $x$ (azul) y negativa en direcciĂłn $y$ (rojo)}}{562}{figure.26.1}%
\contentsline {figure}{\numberline {26.2}{\ignorespaces SecciĂłn transversal del canal abierto en forma de trapecio con ĂĄngulos iguales $\theta $ en la base; $x$ es la longitud del lado doblado.}}{565}{figure.26.2}%
\contentsline {figure}{\numberline {26.3}{\ignorespaces MĂŠtodo de Lagrange: el Ăłptimo ocurre donde una curva de nivel de $f$ (elipse azul) es tangente a la restricciĂłn $g=0$ (recta roja); en ese punto $\nabla f \parallel \nabla g$}}{572}{figure.26.3}%
\contentsline {figure}{\numberline {26.4}{\ignorespaces Curva $y^3=x^2$ con cĂşspide en $(0,0)$; el mĂ­nimo de la distancia al origen ocurre en ese punto, pero $\nabla g=\mathbf {0}$ y el mĂŠtodo de Lagrange falla.}}{574}{figure.26.4}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {27.1}{\ignorespaces (a) RegiĂłn tipo I: $y\in [g_1(x),g_2(x)]$ para cada $x\in [a,b]$. (b) RegiĂłn tipo II: $x\in [h_1(y),h_2(y)]$ para cada $y\in [c,d]$}}{581}{figure.27.1}%
\contentsline {figure}{\numberline {27.2}{\ignorespaces La misma regiĂłn $D$ (entre $y=x^2$ e $y=x$) descrita como tipo I $\DOTSI \intop \ilimits@ _0^1\!\DOTSI \intop \ilimits@ _{x^2}^{x}dy\,dx$ (a) o tipo II $\DOTSI \intop \ilimits@ _0^1\!\DOTSI \intop \ilimits@ _{y}^{\sqrt {y}}dx\,dy$ (b)}}{583}{figure.27.2}%
\contentsline {figure}{\numberline {27.3}{\ignorespaces LĂĄmina rectangular $[0,4]\times [0,3]$ con densidad $\rho (x,y)=y+1$.}}{590}{figure.27.3}%
\contentsline {figure}{\numberline {27.4}{\ignorespaces LĂĄmina acotada por $y=e^x$, $y=0$, $x=0$, $x=1$ con densidad $\rho (x,y)=2-x+y$.}}{590}{figure.27.4}%
\contentsline {figure}{\numberline {27.5}{\ignorespaces LĂĄmina rectangular de ancho $b$ y altura $h$ con densidad uniforme $\rho =1$.}}{592}{figure.27.5}%
\contentsline {figure}{\numberline {27.6}{\ignorespaces Coordenadas polares: el punto $P$ satisface $x=r\cos \theta $, $y=r\sin \theta $; el rectĂĄngulo polar (azul) tiene ĂĄrea $dA = r\,dr\,d\theta $}}{593}{figure.27.6}%
\contentsline {figure}{\numberline {27.7}{\ignorespaces El jacobiano $|J|$ es el factor de escala de ĂĄrea: el cuadrado $R^*=[0,1]^2$ en $(u,v)$ se transforma en la regiĂłn $R$ de ĂĄrea $|J|$ en $(x,y)$}}{599}{figure.27.7}%
\contentsline {figure}{\numberline {27.8}{\ignorespaces LĂĄmina acotada por la curva polar $r=2\mathop {\mathgroup \symoperators sen}\nolimits \theta $ con densidad $\rho (r,\theta )=r$.}}{600}{figure.27.8}%
