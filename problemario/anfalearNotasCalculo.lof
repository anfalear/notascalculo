\contentsline {figure}{\numberline {7.1}{\ignorespaces Representación de un vector geométrico}}{141}{figure.7.1}%
\contentsline {figure}{\numberline {7.2}{\ignorespaces La regla del paralelogramo}}{141}{figure.7.2}%
\contentsline {figure}{\numberline {7.3}{\ignorespaces Vector $\begin {pmatrix} 2\\1 \end {pmatrix}$ en el plano}}{142}{figure.7.3}%
\contentsline {figure}{\numberline {7.4}{\ignorespaces Vector $\begin {pmatrix} 2\\4\\5 \end {pmatrix}$ en el espacio}}{142}{figure.7.4}%
\contentsline {figure}{\numberline {7.5}{\ignorespaces Suma de vectores $\begin {pmatrix} 1\\2\\1 \end {pmatrix}$ y $\begin {pmatrix} 2\\-1\\3 \end {pmatrix}$}}{142}{figure.7.5}%
\contentsline {figure}{\numberline {7.6}{\ignorespaces Resta de vectores $\begin {pmatrix} 3\\2\\1 \end {pmatrix}$ y $\begin {pmatrix} 1\\1\\1 \end {pmatrix}$}}{142}{figure.7.6}%
\contentsline {figure}{\numberline {7.7}{\ignorespaces Multiplicación por escalar: $2\begin {pmatrix} 2\\1\\3 \end {pmatrix}$}}{143}{figure.7.7}%
\contentsline {figure}{\numberline {7.8}{\ignorespaces Vectores del problema \ref {probvectrigo}}}{143}{figure.7.8}%
\contentsline {figure}{\numberline {7.9}{\ignorespaces Norma del vector $\mathbf {u} = \begin {pmatrix} 2 \\ 3 \\ 6 \end {pmatrix}$}}{144}{figure.7.9}%
\contentsline {figure}{\numberline {7.10}{\ignorespaces Vector unitario con dirección de $\mathbf {u}$}}{144}{figure.7.10}%
\contentsline {figure}{\numberline {7.11}{\ignorespaces Ángulo entre vectores}}{145}{figure.7.11}%
\contentsline {figure}{\numberline {7.12}{\ignorespaces Producto cruz entre los vectores $(1,2,0)$ y $(3,4,0)$. El resultado es un vector perpendicular al plano $xy$ con dirección hacia el eje $z$ negativo.}}{146}{figure.7.12}%
\contentsline {figure}{\numberline {7.13}{\ignorespaces Representación geométrica de un plano: El vector normal $\vec {n}$ es perpendicular a cualquier vector contenido en el plano.}}{146}{figure.7.13}%
\contentsline {figure}{\numberline {7.14}{\ignorespaces Triángulo del problema \ref {probtrianguloperimetro}}}{148}{figure.7.14}%
\contentsline {figure}{\numberline {7.15}{\ignorespaces Proyección ortogonal del vector $\mathbf {u}$ sobre el vector $\mathbf {v}.$}}{149}{figure.7.15}%
\contentsline {figure}{\numberline {7.16}{\ignorespaces Representación bidimensional de una recta en el espacio tridimensional $\mathbb {R}^3$. El punto $P(x_0,y_0,z_0)$ es el punto de apoyo, $\vec {d}=(a,b,c)$ es el vector director, y el parámetro $t \in \mathbb {R}$ determina todos los puntos de la recta.}}{150}{figure.7.16}%
\contentsline {figure}{\numberline {7.17}{\ignorespaces Construcción del vector director de la recta perpendicular pedida en el problema \ref {proyrn}: $\mathbf {u}-\text {proy}_{\mathbf {v}}\mathbf {u}$.}}{151}{figure.7.17}%
\contentsline {figure}{\numberline {7.18}{\ignorespaces Rayo incidente, normal a la superficie reflectante y rayo reflejado en el punto de incidencia.}}{151}{figure.7.18}%
\contentsline {figure}{\numberline {7.19}{\ignorespaces Construcción del vector director $\mathbf {v}$ del rayo reflejado a partir de $\operatorname {proy}_{\mathbf {n}}\mathbf {u}$ y de la componente de $\mathbf {u}$ ortogonal a $\mathbf {n}$.}}{152}{figure.7.19}%
\contentsline {figure}{\numberline {7.20}{\ignorespaces Construcción del punto simétrico $S$ del punto $P(0,1,4)$ respecto a la recta $L$.}}{154}{figure.7.20}%
\contentsline {figure}{\numberline {7.21}{\ignorespaces La dirección de la bisectriz en el vértice $B$ es la suma de los vectores unitarios $\frac {\overrightarrow {BA}}{\|\overrightarrow {BA}\|}$ y $\frac {\overrightarrow {BC}}{\|\overrightarrow {BC}\|}$.}}{155}{figure.7.21}%
\contentsline {figure}{\numberline {7.22}{\ignorespaces Triángulo con vértices $A(5,1,2)$, $B(2,8,4)$ y $C(1,-3,7)$ y los vectores $\overrightarrow {AB}$ y $\overrightarrow {AC}$.}}{157}{figure.7.22}%
\contentsline {figure}{\numberline {7.23}{\ignorespaces Mediana trazada desde $A$ hasta el punto medio $D$ del lado $\overline {BC}$.}}{157}{figure.7.23}%
\contentsline {figure}{\numberline {7.24}{\ignorespaces Mediana trazada desde $B$ hasta el punto medio $E$ del lado $\overline {AC}$.}}{157}{figure.7.24}%
