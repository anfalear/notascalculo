\contentsline {figure}{\numberline {32.1}{\ignorespaces Sección del sólido en el plano $xz$. El techo es $z=\sqrt x$ para $0\le x\le 1$ y $z=2-x$ para $1\le x\le 2$; ambas curvas se cortan en $(1,1)$. El volumen es el área de $R$ multiplicada por el grosor $3$ en $y$.}}{744}{figure.32.1}%
\contentsline {figure}{\numberline {32.2}{\ignorespaces Coordenadas cilíndricas $(r,\theta ,z)$: $x=r\cos \theta $, $y=r\mathop {\mathgroup \symoperators sen}\nolimits \theta $, $z=z$; el elemento de volumen es $dV=r\,dr\,d\theta \,dz$}}{746}{figure.32.2}%
\contentsline {figure}{\numberline {32.3}{\ignorespaces Coordenadas esféricas $(\rho ,\varphi ,\theta )$: $x=\rho \mathop {\mathgroup \symoperators sen}\nolimits \varphi \cos \theta $, $y=\rho \mathop {\mathgroup \symoperators sen}\nolimits \varphi \mathop {\mathgroup \symoperators sen}\nolimits \theta $, $z=\rho \cos \varphi $; el elemento de volumen es $dV=\rho ^2\mathop {\mathgroup \symoperators sen}\nolimits \varphi \,d\rho \,d\varphi \,d\theta $}}{747}{figure.32.3}%
\contentsline {figure}{\numberline {32.4}{\ignorespaces Corte en el plano $xz$ del sólido $\Omega $: dentro de la esfera $\rho =2$ (azul), fuera de la esfera desplazada $\rho =2\cos \varphi $ (roja) y sobre el plano $xy$}}{750}{figure.32.4}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {33.1}{\ignorespaces Campo gradiente $\nabla f=(2x,\,\tfrac {y}{2})$ (flechas rojas) perpendicular a las curvas de nivel $f(x,y)=c$ (elipses azules) de $f(x,y)=x^2+\tfrac {y^2}{4}$}}{754}{figure.33.1}%
\contentsline {figure}{\numberline {33.2}{\ignorespaces Campo conservativo $\mathbf {F}(x,y)=(x,y)=\nabla \!\left (\tfrac {x^2+y^2}{2}\right )$: las flechas apuntan radialmente; la integral sobre cualquier curva cerrada $C$ es cero}}{754}{figure.33.2}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {34.1}{\ignorespaces Orientación positiva de $C$: la región $R$ queda siempre a la izquierda; la curva se recorre en sentido antihorario}}{765}{figure.34.1}%
\contentsline {figure}{\numberline {34.2}{\ignorespaces Región tipo\,I en la demostración del Teorema de Green: la franja vertical entre $g_1(x)$ y $g_2(x)$ muestra la aplicación del TFC en $y$. La orientación positiva (antihoraria) de $C$ implica que $C_1$ recorre el borde inferior $\to $ y $C_2$ el superior $\leftarrow $, originando el signo negativo en $-\DOTSI \MultiIntegral {2}_R \partial M/\partial y\,dA$.}}{766}{figure.34.2}%
\contentsline {figure}{\numberline {34.3}{\ignorespaces Arco $C:\,y=\mathop {\mathgroup \symoperators sen}\nolimits x$ de $(0,0)$ a $(\pi ,0)$ (azul), cerrado con el segmento $S$ del eje $x$ (rojo). La región $R$ queda encerrada; su frontera se recorre en sentido positivo tomando el segmento de $(0,0)$ a $(\pi ,0)$ y luego el arco de regreso.}}{768}{figure.34.3}%
\contentsline {figure}{\numberline {34.4}{\ignorespaces Anillo $1\le x^2+y^2\le 4$. La frontera exterior $C_2$ se recorre en sentido antihorario y la interior $C_1$ en sentido horario, dejando la región $R$ siempre a la izquierda.}}{769}{figure.34.4}%
\contentsline {figure}{\numberline {34.5}{\ignorespaces Campo vectorial $\mathbf {F}(x,y)=(-y,\,x)$: vectores tangentes a círculos concéntricos orientados en sentido antihorario ($\nabla \cdot \mathbf {F}=0$;\tmspace +\thickmuskip {.2777em} $\nabla \times \mathbf {F}=2\mathbf {k}$)}}{769}{figure.34.5}%
\contentsline {figure}{\numberline {34.6}{\ignorespaces Superficie orientada $z=4-x^2-y^2$ con vectores normales $\mathbf {n}$ consistentes; invertir la orientación cambia el signo del flujo}}{778}{figure.34.6}%
\contentsline {figure}{\numberline {34.7}{\ignorespaces Cancelación de flujos en caras interiores (flechas rojas opuestas) en el Teorema de la Divergencia: cada cara interna tiene un flujo entrante de una celda y un flujo saliente de la celda vecina, que se anulan. Solo la frontera exterior $\partial Q$ contribuye al flujo neto (flechas azules).}}{780}{figure.34.7}%
\contentsline {figure}{\numberline {34.8}{\ignorespaces Superficie orientada $S$ con borde $\partial S$ (rojo): la orientación de $\partial S$ sigue la regla de la mano derecha respecto de $\mathbf {n}$. Las micro-circulaciones del rotacional (arcos grises) se cancelan entre parches adyacentes; al sumar sobre toda $S$, solo queda la circulación total sobre $\partial S$.}}{783}{figure.34.8}%
\contentsfinish 
