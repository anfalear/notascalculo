\addvspace {10\p@ }
\contentsline {figure}{\numberline {8.1}{\ignorespaces Familia de antiderivadas $F(x)=\frac {x^3}{3}+C$ de $f(x)=x^2$. Las curvas son traslaciones verticales unas de otras y sus rectas tangentes en un mismo $x$ (aquí $x=1$, en rojo) son paralelas, pues todas tienen pendiente $f(1)=1$.}}{174}{figure.8.1}%
\contentsline {figure}{\numberline {8.2}{\ignorespaces Triángulo de referencia del Caso 1, $\sqrt {a^2-u^2}$. Con $u=a\mathop {\mathgroup \symoperators sen}\nolimits \theta $ el radical es el cateto adyacente, $\sqrt {a^2-u^2}=a\cos \theta $.}}{185}{figure.8.2}%
\contentsline {figure}{\numberline {8.3}{\ignorespaces Triángulo de referencia del Caso 2, $\sqrt {a^2+u^2}$. Con $u=a\tan \theta $ el radical es la hipotenusa, $\sqrt {a^2+u^2}=a\sec \theta $.}}{185}{figure.8.3}%
\contentsline {figure}{\numberline {8.4}{\ignorespaces Triángulo de referencia del Caso 3, $\sqrt {u^2-a^2}$. Con $u=a\sec \theta $ el radical es el cateto opuesto, $\sqrt {u^2-a^2}=a\tan \theta $.}}{186}{figure.8.4}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {9.1}{\ignorespaces Método de exhaución de Arquímedes: polígonos regulares inscritos en el círculo (azul, $n=6$; rojo, $n=12$). Al crecer $n$ el área del polígono se aproxima al área del círculo (negro) por defecto.}}{193}{figure.9.1}%
\contentsline {figure}{\numberline {9.2}{\ignorespaces Suma de Riemann con $n=7$ subintervalos, tomando como punto de muestra el extremo derecho de cada uno. La suma de las áreas de los rectángulos aproxima el área bajo la curva; al refinar la partición ($\|P\|\to 0$) la aproximación tiende a la integral definida.}}{194}{figure.9.2}%
\contentsline {figure}{\numberline {9.3}{\ignorespaces Interpretación de la integral definida como \emph {área neta}: la región sobre el eje $x$ (verde, $A^+$) aporta con signo positivo y la región bajo el eje (roja, $A^-$) con signo negativo, de modo que $\DOTSI \intop \ilimits@ _a^b f = A^+ - A^-$.}}{196}{figure.9.3}%
\contentsline {figure}{\numberline {9.4}{\ignorespaces Función de acumulación $F(x)=\DOTSI \intop \ilimits@ _a^x f(t)\,dt$: el área sombreada depende del extremo derecho móvil $x$. El TFC1 afirma que la razón a la que crece esta área al desplazar $x$ es exactamente $f(x)$.}}{197}{figure.9.4}%
\contentsline {figure}{\numberline {9.5}{\ignorespaces Teorema del Valor Medio para Integrales: existe $c\in (a,b)$ tal que el rectángulo de base $b-a$ y altura $f(c)=\bar f$ (verde) tiene exactamente la misma área que la región bajo la curva, es decir $f(c)(b-a)=\DOTSI \intop \ilimits@ _a^b f(x)\,dx$.}}{200}{figure.9.5}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {10.1}{\ignorespaces Región limitada por la curva y el eje $x$ en $[-1,1]$. El tramo situado sobre el eje (azul) aporta área positiva y el situado bajo el eje (rojo) aporta área negativa, de modo que el área geométrica exige integrar el valor absoluto en cada subintervalo.}}{204}{figure.10.1}%
\contentsline {figure}{\numberline {10.2}{\ignorespaces Región acotada por la parábola $y=x^2$ y la recta $y=x+2$. Las curvas se cortan en $x=-1$ y $x=2$, y en todo ese intervalo la recta queda por encima de la parábola.}}{205}{figure.10.2}%
\contentsline {figure}{\numberline {10.3}{\ignorespaces Región comprendida entre $y=\mathop {\mathgroup \symoperators sen}\nolimits x$ y $y=\cos x$ en $[0,2\pi ]$. La curva superior cambia en $x=\pi /4$ y $x=5\pi /4$, lo que obliga a partir el intervalo en tres tramos.}}{206}{figure.10.3}%
\contentsline {figure}{\numberline {10.4}{\ignorespaces Región acotada por la parábola $x=y^2$ y la recta $x=y+2$. Integrando respecto a $y$ en $[-1,2]$ la región es de un solo tipo y basta una integral.}}{207}{figure.10.4}%
\contentsline {figure}{\numberline {10.5}{\ignorespaces Región acotada por $y=\sqrt {x}$, la recta $y=x-2$ y el eje $x$. Al integrar respecto a $y$ en $[0,2]$ se evita partir el cálculo en dos integrales.}}{208}{figure.10.5}%
\contentsline {figure}{\numberline {10.6}{\ignorespaces Generación del cono de radio $R$ y altura $h$ al girar la recta $y=\frac {R}{h}x$ alrededor del eje $x$. Cada corte perpendicular al eje es un disco de radio $r(x)=\frac {R}{h}x$.}}{209}{figure.10.6}%
\contentsline {figure}{\numberline {10.7}{\ignorespaces Generación de la esfera de radio $R$ al girar la semicircunferencia $y=\sqrt {R^2-x^2}$ alrededor del eje $x$. El disco en la posición $x$ tiene radio $\sqrt {R^2-x^2}$.}}{209}{figure.10.7}%
\contentsline {figure}{\numberline {10.8}{\ignorespaces Región entre $y=\sqrt {x}$ y $y=x^2$ en $[0,1]$. Al girar alrededor del eje $x$, cada corte es una arandela de radio externo $R(x)=\sqrt {x}$ y radio interno $r(x)=x^2$.}}{210}{figure.10.8}%
\contentsline {figure}{\numberline {10.9}{\ignorespaces Giro alrededor de la recta $y=2$, situada por encima de la región. Los radios se miden como distancias al eje de rotación, no al eje $x$.}}{211}{figure.10.9}%
\contentsline {figure}{\numberline {10.10}{\ignorespaces Región bajo $y=\sqrt {x}$ en $[0,4]$ girada alrededor del eje $y$. Cada franja vertical genera un cascarón cilíndrico de radio $x$ y altura $\sqrt {x}$.}}{212}{figure.10.10}%
\contentsline {figure}{\numberline {10.11}{\ignorespaces Giro alrededor de la recta vertical $x=5$, situada a la derecha de la región. La franja en $x$ genera un cascarón de radio $r(x)=5-x$ y altura $h(x)=4x-x^2$.}}{213}{figure.10.11}%
\contentsline {figure}{\numberline {10.12}{\ignorespaces Arco de parábola cuya longitud se calcula con $ds=\sqrt {1+[f'(x)]^2}\,dx$: el elemento de arco es la hipotenusa del triángulo diferencial de catetos $dx$ y $dy$.}}{214}{figure.10.12}%
\contentsline {figure}{\numberline {10.13}{\ignorespaces Catenaria $y=\cosh x$, simétrica respecto al eje $y$. Sus propiedades hiperbólicas hacen que el radicando $1+(y')^2$ sea un cuadrado perfecto.}}{215}{figure.10.13}%
\contentsline {figure}{\numberline {10.14}{\ignorespaces Superficie esférica generada al girar la semicircunferencia $y=\sqrt {R^2-x^2}$ alrededor del eje $x$. La banda elemental tiene área $dS=2\pi y\,ds$.}}{216}{figure.10.14}%
\contentsline {figure}{\numberline {10.15}{\ignorespaces Superficie generada al girar la parábola $y=x^2$ alrededor del eje $y$. El radio de giro es la distancia horizontal al eje, $r(x)=x$.}}{217}{figure.10.15}%
\contentsline {figure}{\numberline {10.16}{\ignorespaces Trabajo como área bajo la recta $F(x)=100x$ en $[0,\,0.3]$. Al ser la fuerza proporcional al estiramiento, el área es la de un triángulo.}}{218}{figure.10.16}%
\contentsline {figure}{\numberline {10.17}{\ignorespaces Trabajo adicional (azul) para estirar el resorte de $x=0.05$ a $x=0.20$ m. El área gris corresponde al trabajo ya realizado y no se contabiliza.}}{219}{figure.10.17}%
\contentsline {figure}{\numberline {10.18}{\ignorespaces Tanque cónico invertido: la rebanada a altura $y$ tiene radio $r(y)=y/2$ y debe elevarse la distancia $6-y$ hasta el borde.}}{219}{figure.10.18}%
\contentsline {figure}{\numberline {10.19}{\ignorespaces Tanque cilíndrico: a diferencia del cónico, la sección transversal es constante ($A=4\pi \,\text {m}^2$) y solo varía la distancia de elevación $5-y$.}}{220}{figure.10.19}%
\contentsline {figure}{\numberline {10.20}{\ignorespaces Región triangular de vértices $(0,0)$, $(1,0)$ y $(0,1)$ con densidad constante. El centroide es el punto de equilibrio de la lámina.}}{221}{figure.10.20}%
\contentsline {figure}{\numberline {10.21}{\ignorespaces Lámina semicircular de radio $R$. La simetría respecto al eje $y$ obliga a $\bar x=0$, de modo que solo hay que calcular $\bar y$.}}{222}{figure.10.21}%
\contentsline {figure}{\numberline {10.22}{\ignorespaces Varilla homogénea de longitud $L$ girando respecto a un eje que pasa por uno de sus extremos ($x=0$).}}{223}{figure.10.22}%
\contentsline {figure}{\numberline {10.23}{\ignorespaces Misma varilla girando respecto a un eje que pasa por su centro: al situar el origen en el punto medio, la integral se extiende a $[-L/2,\,L/2]$ y el momento de inercia resulta menor.}}{224}{figure.10.23}%
\contentsline {figure}{\numberline {10.24}{\ignorespaces Compuerta rectangular sumergida entre las profundidades $h=2$ m y $h=5$ m. La presión crece linealmente con la profundidad, de modo que la fuerza se obtiene integrando franjas horizontales.}}{224}{figure.10.24}%
\contentsline {figure}{\numberline {10.25}{\ignorespaces Región $R$ limitada por $y=x+6$, $y=-x^2-6x-6$ y $x=0$.}}{225}{figure.10.25}%
\contentsline {figure}{\numberline {10.26}{\ignorespaces Región encerrada por $y=2x+4$, $y=-2x^2-4x$ y $x=0$, que se hace girar alrededor del eje $x$.}}{226}{figure.10.26}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {11.1}{\ignorespaces Interpretación de la integral impropia de primer tipo como límite de un área: la región sombreada $A(t)=\DOTSI \intop \ilimits@ _a^t f(x)\,dx$ crece al desplazar la frontera móvil $t$ hacia la derecha. La integral $\DOTSI \intop \ilimits@ _a^\infty f$ converge si $A(t)$ tiende a un valor finito cuando $t\to \infty $.}}{230}{figure.11.1}%
\contentsline {figure}{\numberline {11.2}{\ignorespaces Región bajo $f(x)=xe^{-x}$ para $x\geq 0$: parte del origen, alcanza su máximo en $x=1$ y decae a $0$. El área infinita hacia la derecha se calcula como límite con la frontera móvil $b\to \infty $.}}{231}{figure.11.2}%
\contentsline {figure}{\numberline {11.3}{\ignorespaces La función par $f(x)=\tfrac {1}{1+x^2}$ con máximo $f(0)=1$ y asíntota horizontal $y=0$. La región bajo la curva se extiende infinitamente a ambos lados, por lo que la integral se parte en $c=0$.}}{232}{figure.11.3}%
\contentsline {figure}{\numberline {11.4}{\ignorespaces Densidad de probabilidad: el parámetro $k$ se fija exigiendo que el área total bajo la curva valga exactamente $1$ (condición de normalización).}}{233}{figure.11.4}%
\contentsline {figure}{\numberline {11.5}{\ignorespaces Densidad exponencial con $f(0)=2$: el área azul representa $P(X<0.5)$, una fracción del área total, que es $1$.}}{235}{figure.11.5}%
\contentsline {figure}{\numberline {11.6}{\ignorespaces Región bajo $f(x)=x^{-1/2}$ en $(0,1]$: infinita en altura por la singularidad en $x=0^+$, pero confinada horizontalmente. El decaimiento rápido hace que el área sea finita.}}{237}{figure.11.6}%
\contentsline {figure}{\numberline {11.7}{\ignorespaces Integrando con cúspide vertical asintótica en $x=1$: es obligatorio separar la integral en $[0,1)$ (Izq.) y $(1,3]$ (Der.), pues aplicar el TFC a través de la discontinuidad da un resultado erróneo.}}{238}{figure.11.7}%
\contentsline {figure}{\numberline {11.8}{\ignorespaces Trompeta de Gabriel: la curva $y=1/x$ para $x\geq 1$ girada alrededor del eje $x$. Los discos perpendiculares tienen radio $R(x)=1/x$; el sólido tiene volumen finito pero área de superficie infinita.}}{239}{figure.11.8}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {12.1}{\ignorespaces Curva paramétrica con un nodo: la recta tangente en $(4,2)$ tiene pendiente $m=9/4$ y ecuación $y=\tfrac {9}{4}x-7$.}}{246}{figure.12.1}%
\contentsline {figure}{\numberline {12.2}{\ignorespaces Curva paramétrica situada íntegramente por debajo del eje $x$ entre $P_0(0,-5)$ y $P_1(8,-1)$: el área encerrada resulta con signo negativo, por lo que se toma su valor absoluto.}}{248}{figure.12.2}%
\contentsline {figure}{\numberline {12.3}{\ignorespaces Circunferencia de radio $R$ centrada en el origen, parametrizada y recorrida en sentido antihorario al crecer $t$ (se ilustra con $R=1$).}}{249}{figure.12.3}%
\contentsline {figure}{\numberline {12.4}{\ignorespaces Un arco de cicloide: parte del origen en $t=0$, alcanza la cúspide $(\pi a,2a)$ en $t=\pi $ y regresa al eje $x$ en $(2\pi a,0)$ cuando $t=2\pi $.}}{250}{figure.12.4}%
\contentsline {figure}{\numberline {12.5}{\ignorespaces Coordenadas polares de un punto: el radio $r$ y el ángulo $\theta $ medido desde el eje polar, junto con las relaciones $x=r\cos \theta $, $y=r\mathop {\mathgroup \symoperators sen}\nolimits \theta $.}}{251}{figure.12.5}%
\contentsline {figure}{\numberline {12.6}{\ignorespaces Cardioide $r=a(1+\cos \theta )$: curva cerrada con cúspide en el polo, radio máximo $r=2a$ en $\theta =0$ y simetría respecto al eje polar.}}{252}{figure.12.6}%
\contentsline {figure}{\numberline {12.7}{\ignorespaces Rosas polares $r=\cos (n\theta )$: con $n$ impar se obtienen $n$ pétalos (aquí $r=\cos 3\theta $, 3 pétalos) y con $n$ par se obtienen $2n$ pétalos (aquí $r=\cos 2\theta $, 4 pétalos).}}{253}{figure.12.7}%
\contentsline {figure}{\numberline {12.8}{\ignorespaces Lemniscata $r^2=a^2\cos (2\theta )$: dos bucles simétricos definidos donde $\cos (2\theta )\geq 0$, con ancho máximo $r=a$ en $\theta =0$.}}{254}{figure.12.8}%
\contentsline {figure}{\numberline {12.9}{\ignorespaces Espiral de Arquímedes $r=a\theta $: a diferencia de las curvas cerradas, se aleja indefinidamente del polo; con $a=1/(2\pi )$ cada vuelta aumenta $r$ en una unidad.}}{254}{figure.12.9}%
\contentsline {figure}{\numberline {12.10}{\ignorespaces Rosa $r=\mathop {\mathgroup \symoperators sen}\nolimits (3\theta )$: el pétalo principal se genera al variar $\theta \in [0,\pi /3]$, intervalo donde $r\geq 0$; su área se calcula con $\tfrac 12\DOTSI \intop \ilimits@ r^2\,d\theta $.}}{255}{figure.12.10}%
\contentsline {figure}{\numberline {12.11}{\ignorespaces Dos cardioides, $r=1+\cos \theta $ (hacia la derecha) y $r=1-\mathop {\mathgroup \symoperators sen}\nolimits \theta $ (hacia abajo): se cruzan en dos puntos y comparten el polo, lo que delimita la región común.}}{256}{figure.12.11}%
\contentsline {figure}{\numberline {12.12}{\ignorespaces Arco de espiral cuyo longitud se calcula: crecimiento lineal $r$ frente a $\theta $, desde el polo hasta el punto $(2\pi ,0)$ en cartesianas tras una vuelta completa.}}{258}{figure.12.12}%
