\addvspace {10\p@ }
\contentsline {figure}{\numberline {24.1}{\ignorespaces Sumas parciales $S_n=\DOTSB \sum@ \slimits@ _{k=1}^n k^2$: los valores $S_1=1,\,S_2=5,\,S_3=14,\,S_4=30$ crecen sin cota, coherente con la fórmula cerrada $n(n+1)(2n+1)/6$.}}{578}{figure.24.1}%
\contentsline {figure}{\numberline {24.2}{\ignorespaces Convergencia de una sucesión: $a_n\to L$ significa que para cada margen $\varepsilon >0$ existe un umbral $N$ tal que todos los términos con $n>N$ caen dentro de la banda $(L-\varepsilon ,\,L+\varepsilon )$. Solo un número finito de términos (los de índice $n\leq N$) puede quedar fuera.}}{579}{figure.24.2}%
\contentsline {figure}{\numberline {24.3}{\ignorespaces Términos de $a_n=\mathop {\mathgroup \symoperators sen}\nolimits ^2 n/n$: oscilan de forma irregular por el numerador $\mathop {\mathgroup \symoperators sen}\nolimits ^2 n\in [0,1]$, pero quedan comprimidos hacia $0$ por el factor $1/n$.}}{580}{figure.24.3}%
\contentsline {figure}{\numberline {24.4}{\ignorespaces Sucesión no monótona: crece hasta $n=3$ ($a_3=1.125$) y decrece después. El comportamiento monótono solo aparece a partir de cierto índice.}}{581}{figure.24.4}%
\contentsline {figure}{\numberline {24.5}{\ignorespaces Sucesión recursiva cuyos términos oscilan y se estabilizan hacia el límite $L=\sqrt {3}-1$, dentro de la banda $[0.6,0.9]$.}}{582}{figure.24.5}%
\contentsline {figure}{\numberline {24.6}{\ignorespaces Extensión continua $f(x)=(1+\ln x)/x^2$ usada para aplicar L'Hôpital: cerca de $x\to 0^+$ el cociente tiende a $-\infty $, lo que determina el límite de la sucesión asociada.}}{585}{figure.24.6}%
\contentsline {figure}{\numberline {24.7}{\ignorespaces Cocientes $a_n/b_n$ con $a_n=\DOTSB \sum@ \slimits@ k^{1/3}$ y $b_n=n^{4/3}$: los valores $0.814,\,0.789,\,0.763,\,0.758$ sugieren convergencia a $3/4$ (criterio de Stolz-Cesàro).}}{586}{figure.24.7}%
\contentsline {figure}{\numberline {24.8}{\ignorespaces Demostración visual de $\DOTSB \sum@ \slimits@ _{n=1}^\infty 2^{-n}=1$: cada término cubre la mitad del área restante del cuadrado unitario ($\tfrac 12$, luego $\tfrac 14$, $\tfrac 18$, \ldots ), de modo que la unión de todos los rectángulos llena el cuadrado completo de área $1$.}}{588}{figure.24.8}%
\contentsline {figure}{\numberline {24.9}{\ignorespaces Sumas parciales de una serie de términos positivos: crecen monótonamente y se acercan a un valor finito cercano a $11/6$, indicio de convergencia.}}{588}{figure.24.9}%
\contentsline {figure}{\numberline {24.10}{\ignorespaces Términos $a_n$ que decrecen lentamente ($a_{100}\approx 0.00217$): el análisis gráfico sugiere convergencia, pero exige un criterio (integral o comparación) para confirmarla.}}{589}{figure.24.10}%
\contentsline {figure}{\numberline {24.11}{\ignorespaces Términos con $n!$ y $n^n$ que crecen y luego decrecen: la presencia de factoriales y potencias hace idóneo el criterio del cociente.}}{591}{figure.24.11}%
\contentsline {figure}{\numberline {24.12}{\ignorespaces Sumas parciales de una serie alternante: oscilan entre dos envolventes que se comprimen hacia el límite $\approx 0.605$, tal como garantiza el criterio de Leibniz.}}{593}{figure.24.12}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {25.1}{\ignorespaces Convergencia uniforme $f_n\rightrightarrows f$: para $n$ suficientemente grande, la gráfica completa de $f_n$ queda atrapada dentro de la banda de anchura $2\varepsilon $ alrededor de $f$. Un único $N(\varepsilon )$ sirve para todos los $x$ a la vez, y la banda se estrecha al hacer $\varepsilon \to 0$.}}{598}{figure.25.1}%
\contentsline {figure}{\numberline {25.2}{\ignorespaces Sucesión de funciones que converge puntualmente pero no uniformemente: aunque cada $f_n$ tiende al límite en cada punto, el error máximo sobre el intervalo no tiende a cero.}}{598}{figure.25.2}%
\contentsline {figure}{\numberline {25.3}{\ignorespaces Sucesión de funciones lineales que converge uniformemente en $[0,1]$: el error máximo $\sup |f_n-f|$ tiende a cero al aumentar $n$.}}{599}{figure.25.3}%
\contentsline {figure}{\numberline {25.4}{\ignorespaces Pico viajero: la joroba de altura fija se desplaza hacia la derecha al crecer $n$. La convergencia es puntual a $0$ pero no uniforme en $[0,\infty )$, pues el supremo no decae.}}{600}{figure.25.4}%
\contentsline {figure}{\numberline {25.5}{\ignorespaces Ejemplo donde el límite de las derivadas no coincide con la derivada del límite: la sucesión converge uniformemente pero las derivadas no, de modo que el intercambio límite-derivada falla.}}{601}{figure.25.5}%
\contentsline {figure}{\numberline {25.6}{\ignorespaces Serie trigonométrica cuya convergencia uniforme se establece con el criterio-M de Weierstrass: las sumas parciales se aproximan uniformemente a la función suma, continua e integrable.}}{604}{figure.25.6}%
\contentsline {figure}{\numberline {25.7}{\ignorespaces Serie geométrica alternada $\DOTSB \sum@ \slimits@ (-x)^n$: converge uniformemente en cada compacto $[0,r]$ con $r<1$, pero no en todo $(-1,1)$, donde la convergencia se degrada cerca de los extremos.}}{605}{figure.25.7}%
\contentsline {figure}{\numberline {25.8}{\ignorespaces Función de Weierstrass: suma uniformemente convergente de cosenos con frecuencias crecientes, continua en todo punto pero derivable en ninguno por su estructura autosemejante.}}{606}{figure.25.8}%
\contentsline {figure}{\numberline {25.9}{\ignorespaces Radio de convergencia sobre la recta real: una serie de potencias centrada en $c$ converge absolutamente en el intervalo abierto $(c-R,\,c+R)$, diverge fuera de $[c-R,\,c+R]$, y en los extremos $x=c\pm R$ el comportamiento debe analizarse por separado en cada caso.}}{609}{figure.25.9}%
\contentsline {figure}{\numberline {25.10}{\ignorespaces Cuatro casos canónicos de radio de convergencia, incluido el caso $R=\infty $ de la serie de $e^x$, que converge en toda la recta.}}{609}{figure.25.10}%
\contentsline {figure}{\numberline {25.11}{\ignorespaces Suma en forma cerrada obtenida derivando término a término la serie geométrica: la operación es válida en el interior del intervalo de convergencia.}}{610}{figure.25.11}%
\contentsline {figure}{\numberline {25.12}{\ignorespaces Serie logarítmica $\DOTSB \sum@ \slimits@ (-1)^{n+1}x^n/n$: la suma por integración término a término da $\ln (1+x)$, y el Teorema de Abel permite evaluar en $x=1$ para obtener $\DOTSB \sum@ \slimits@ (-1)^n/n=-\ln 2$.}}{611}{figure.25.12}%
\contentsline {figure}{\numberline {25.13}{\ignorespaces Aplicaciones de las series de potencias: cálculo de límites, integrales sin primitiva elemental y estimación del error de truncamiento mediante el resto.}}{614}{figure.25.13}%
\contentsline {figure}{\numberline {25.14}{\ignorespaces Función $C^\infty $ que no es analítica en el origen: todas sus derivadas se anulan en $0$, por lo que su serie de Taylor es idénticamente nula y no representa a la función en ningún entorno.}}{616}{figure.25.14}%
\ttl@tocsep 
\addvspace {10\p@ }
\contentsline {figure}{\numberline {26.1}{\ignorespaces Campo de pendientes de \(y'=x-y\) con tres curvas solución \(y=x-1+Ce^{-x}\) (\(C=1,0,-1\)). Todas convergen a la recta \(y=x-1\) (\(C=0\), en rojo) cuando \(x\to \infty \).}}{622}{figure.26.1}%
\contentsline {figure}{\numberline {26.2}{\ignorespaces Ley de enfriamiento de Newton \(T(t)=T_a+(T_0-T_a)e^{-kt}\) con \(T_a=20\), \(k=0.35\). Toda curva tiende asintóticamente a la temperatura ambiente; la de \(T_0=5\) corresponde a un cuerpo que se calienta.}}{630}{figure.26.2}%
\contentsline {figure}{\numberline {26.3}{\ignorespaces Circuito RL en serie con fuente de voltaje \(E(t)\). La corriente \(i(t)\) satisface \(L\,i'+R\,i=E(t)\).}}{631}{figure.26.3}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {27.1}{\ignorespaces Sistema masa--resorte--amortiguador: masa \(m\), constante del resorte \(k\), coeficiente de amortiguamiento \(c\) y fuerza externa \(F(t)\). El desplazamiento \(x(t)\) se mide desde la posición de equilibrio y satisface \(mx''+cx'+kx=F(t)\).}}{642}{figure.27.1}%
\contentsline {figure}{\numberline {27.2}{\ignorespaces Los cuatro comportamientos del oscilador \(mx''+cx'+kx=F(t)\): subamortiguado (oscila y decae), crítico y sobreamortiguado (decaen sin oscilar), y resonancia (amplitud creciente cuando la forzante coincide con la frecuencia natural \(\omega _0=\sqrt {k/m}\)).}}{643}{figure.27.2}%
\contentsline {figure}{\numberline {27.3}{\ignorespaces Circuito RLC en serie. La carga \(Q(t)\) del capacitor satisface \(LQ''+RQ'+\tfrac {1}{C}Q=E(t)\), análoga a \(mx''+cx'+kx=F(t)\) con \(m\leftrightarrow L\), \(c\leftrightarrow R\), \(k\leftrightarrow 1/C\).}}{643}{figure.27.3}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {28.1}{\ignorespaces Retratos de fase de $\mathbf {X}'=A\mathbf {X}$ según el espectro de $A$: (a) \emph {nodo} —valores propios reales del mismo signo, trayectorias que entran (o salen) del origen; (b) \emph {foco} —valores propios complejos, espiral; (c) \emph {punto silla} —valores propios reales de signo opuesto, con separatrices estable (verde, entra) e inestable (roja, sale).}}{656}{figure.28.1}%
\contentsline {figure}{\numberline {28.2}{\ignorespaces Dos masas $m_1,m_2$ acopladas por tres resortes ($k_1,k_2,k_3$) entre paredes fijas. Los desplazamientos $x_1,x_2$ desde el equilibrio satisfacen un sistema lineal de segundo orden acoplado.}}{659}{figure.28.2}%
\contentsline {figure}{\numberline {28.3}{\ignorespaces Circuito de dos mallas acopladas por inductancia mutua $M$. Las corrientes $i_1(t),i_2(t)$ satisfacen $L_1i_1'+R_1i_1+Mi_2'=E_1$ y $Mi_1'+L_2i_2'+R_2i_2=E_2$.}}{661}{figure.28.3}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {29.1}{\ignorespaces El desarrollo en serie alrededor de un punto ordinario $x_0$ converge al menos en el disco de radio $R$ igual a la distancia a la singularidad más cercana de la ecuación (en el plano complejo).}}{671}{figure.29.1}%
\contentsline {figure}{\numberline {29.2}{\ignorespaces Funciones de Bessel de primera especie $J_0,J_1,J_2$. Oscilan con amplitud decreciente ($\sim x^{-1/2}$); sus infinitos ceros determinan las frecuencias propias en problemas con simetría cilíndrica.}}{677}{figure.29.2}%
\contentsline {figure}{\numberline {29.3}{\ignorespaces Polinomios de Legendre $P_0,\dots ,P_3$ en $[-1,1]$. Cada $P_n$ tiene $n$ ceros en el intervalo, satisface $P_n(1)=1$ y tiene la paridad de $n$; son mutuamente ortogonales.}}{678}{figure.29.3}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {30.1}{\ignorespaces Función escalón unitario de Heaviside $u(t-a)$: vale $0$ para $t<a$ y salta a $1$ en $t=a$.}}{691}{figure.30.1}%
\contentsline {figure}{\numberline {30.2}{\ignorespaces La delta de Dirac $\delta (t-a)$ como límite de pulsos rectangulares de área $1$: al estrecharse ($\epsilon \to 0^+$) la altura crece manteniendo el área, concentrando toda la masa en $t=a$ (flecha).}}{692}{figure.30.2}%
\contentsline {figure}{\numberline {30.3}{\ignorespaces Convolución de $f(t)=e^{-t}$ y $g(t)=e^{-2t}$: $(f*g)(t)=\DOTSI \intop \ilimits@ _0^t f(\tau )g(t-\tau )\,d\tau =e^{-t}-e^{-2t}$. El Teorema~\ref {thm:cap31:convolucion} la convierte en un producto, $\mathcal L\{f*g\}=F(s)G(s)$.}}{694}{figure.30.3}%
