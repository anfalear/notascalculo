\contentsline {figure}{\numberline {31.1}{\ignorespaces (a) Región tipo I: $y\in [g_1(x),g_2(x)]$ para cada $x\in [a,b]$. (b) Región tipo II: $x\in [h_1(y),h_2(y)]$ para cada $y\in [c,d]$}}{711}{figure.31.1}%
\contentsline {figure}{\numberline {31.2}{\ignorespaces La misma región $D$ (entre $y=x^2$ e $y=x$) descrita como tipo I $\DOTSI \intop \ilimits@ _0^1\!\DOTSI \intop \ilimits@ _{x^2}^{x}dy\,dx$ (a) o tipo II $\DOTSI \intop \ilimits@ _0^1\!\DOTSI \intop \ilimits@ _{y}^{\sqrt {y}}dx\,dy$ (b)}}{713}{figure.31.2}%
\contentsline {figure}{\numberline {31.3}{\ignorespaces Lámina rectangular $[0,4]\times [0,3]$ con densidad $\rho (x,y)=y+1$.}}{719}{figure.31.3}%
\contentsline {figure}{\numberline {31.4}{\ignorespaces Lámina acotada por $y=e^x$, $y=0$, $x=0$, $x=1$ con densidad $\rho (x,y)=2-x+y$.}}{720}{figure.31.4}%
\contentsline {figure}{\numberline {31.5}{\ignorespaces Lámina rectangular de ancho $b$ y altura $h$ con densidad uniforme $\rho =1$.}}{721}{figure.31.5}%
\contentsline {figure}{\numberline {31.6}{\ignorespaces Coordenadas polares: el punto $P$ satisface $x=r\cos \theta $, $y=r\mathop {\mathgroup \symoperators sen}\nolimits \theta $; el rectángulo polar (azul) tiene área $dA = r\,dr\,d\theta $}}{722}{figure.31.6}%
\contentsline {figure}{\numberline {31.7}{\ignorespaces Región $R$ comprendida entre la recta $y=x$ y la parábola $y=x^2/2$ (isomorfa de la conversión a polares con región no circular). Un rayo genérico de ángulo $\theta \in [0,\pi /4]$ recorre la región desde el origen hasta la parábola, en $r=2\tan \theta \sec \theta $.}}{729}{figure.31.7}%
\contentsline {figure}{\numberline {31.8}{\ignorespaces El jacobiano $|J|$ es el factor de escala de área: el cuadrado $R^*=[0,1]^2$ en $(u,v)$ se transforma en la región $R$ de área $|J|$ en $(x,y)$}}{730}{figure.31.8}%
\contentsline {figure}{\numberline {31.9}{\ignorespaces Lámina acotada por la curva polar $r=2\mathop {\mathgroup \symoperators sen}\nolimits \theta $ con densidad $\rho (r,\theta )=r$.}}{731}{figure.31.9}%
